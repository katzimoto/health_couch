# ─── Health Coach configuration ───────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ── Garmin Connect ────────────────────────────────────────────────────────────
# Used only for the one-time `scripts/garmin_login.py`. After login, auth tokens
# are cached in ./garmin-tokens and these can be left blank.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# ── LLM (coach.py: morning plan + Telegram chat) ────────────────────────────────
# Any OpenAI-compatible chat completions API works — set OPENAI_BASE_URL to use
# a provider other than OpenAI itself. Currently using Groq's free tier (no
# card required): https://api.groq.com/openai/v1, model "openai/gpt-oss-120b".
# Leave OPENAI_BASE_URL blank to use OpenAI directly instead.
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot with @BotFather to get the token, then run
# `python scripts/get_chat_id.py` to discover your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── MCP server ────────────────────────────────────────────────────────────────
# Preferred: OAuth via WorkOS AuthKit (needed for ChatGPT's connector). Create a
# free WorkOS project, enable Dynamic Client Registration, disable sign-up, and
# invite only yourself as a user. AUTHKIT_DOMAIN is the environment's AuthKit
# domain (Dashboard → Configuration, or discoverable via a redirect from
# https://api.workos.com/user_management/authorize?client_id=...).
# MCP_PUBLIC_URL is this server's public base URL (no path).
AUTHKIT_DOMAIN=
MCP_PUBLIC_URL=
# Fallback bearer token, used only if AUTHKIT_DOMAIN is unset. Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_BEARER_TOKEN=
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ── Web dashboard ─────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8050
# Optional shared secret. If set, the dashboard requires ?token=... (or an
# X-Dashboard-Token header). Leave blank for localhost/LAN-only use.
DASHBOARD_TOKEN=

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Token from `cloudflared tunnel` (Zero Trust dashboard). Leave blank to skip.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Coaching ──────────────────────────────────────────────────────────────────
# Free-text goals injected into the coach system prompt.
COACH_GOALS=Lose 4 kg of fat, improve skin, and have more daily energy.
# Local time the morning plan is pushed (24h HH:MM).
MORNING_PLAN_TIME=07:30
# IANA timezone for the scheduler.
TZ=Europe/Berlin

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=/app/data/health.db
# Days of history to import on first run.
BACKFILL_DAYS=90
