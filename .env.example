# ─── Health Coach configuration ───────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ── Garmin Connect ────────────────────────────────────────────────────────────
# Used only for the one-time `scripts/garmin_login.py`. After login, auth tokens
# are cached in ./garmin-tokens and these can be left blank.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot with @BotFather to get the token, then run
# `python scripts/get_chat_id.py` to discover your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── MCP server ────────────────────────────────────────────────────────────────
# Bearer token protecting the public MCP endpoint. Generate a strong random one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_BEARER_TOKEN=
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Token from `cloudflared tunnel` (Zero Trust dashboard). Leave blank to skip.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Coaching ──────────────────────────────────────────────────────────────────
# Free-text goals injected into the coach system prompt.
COACH_GOALS=Lose 4 kg of fat, improve skin, and have more daily energy.
# Local time the morning plan is pushed (24h HH:MM).
MORNING_PLAN_TIME=07:30
# IANA timezone for the scheduler.
TZ=Europe/Berlin

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=/app/data/health.db
# Days of history to import on first run.
BACKFILL_DAYS=90
